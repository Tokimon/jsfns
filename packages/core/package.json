{
	"name": "@jsfns/core",
	"version": "1.2.1",
	"description": "Simple, no dependency, JS utility functions",
	"private": false,
	"author": "Toke Voltelen",
	"license": "MIT",
	"type": "module",
	"main": "./index.js",
	"module": "./index.mjs",
	"types": "./index.d.ts",
	"typings": "./index.d.ts",
	"repository": {
		"type": "git",
		"url": "git+https://Tokimon@github.com/Tokimon/jsfns.git"
	},
	"keywords": [
		"javascript",
		"helpers",
		"snippets",
		"utility",
		"tool"
	],
	"bugs": {
		"url": "https://github.com/Tokimon/jsfns/issues"
	},
	"homepage": "https://tokimon.github.io/jsfns-docs/core",
	"scripts": {
		"prepublishOnly": "pnpm test:coverage:json && pnpm build && esrun ../../readme-builder/build.ts",
		"postpublish": "pnpm clean",
		"dry-run": "pnpm validate && pnpm build && npm pack --dry-run && pnpm clean",
		"build": "../../bin/build.sh",
		"clean": "../../bin/clean.sh",
		"missing": "../../bin/missing.sh",
		"readme": "pnpm test:coverage:json && esrun ../../readme-builder/build.ts",
		"typecheck": "tsgo -p tsconfig.json",
		"test": "vitest run",
		"test:coverage:json": "vitest run --coverage.reporter=json-summary",
		"typedoc:validate": "typedoc --entryPoints \"src/*.ts\" --validation --treatWarningsAsErrors --emit none",
		"lint": "biome check",
		"format": "biome check --write",
		"validate": "biome check && pnpm typecheck && pnpm typedoc:validate && pnpm test",
		"release": "pnpm publish"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@typescript/native-preview": "7.0.0-dev.20260412.1",
		"typedoc": "^0.28.19",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.4"
	},
	"files": [
		"/*.js",
		"/*.cjs",
		"/*.mjs",
		"/*.d.ts",
		"/README.md",
		"/LICENSE",
		"!/vitest.*.ts",
		"!/readme/*"
	]
}
