{
	"name": "@jsfns/web",
	"version": "2.1.0",
	"description": "Simple, no dependency, JS utility functions for use in a browser environment",
	"private": false,
	"author": "Toke Voltelen",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Tokimon/jsfns.git"
	},
	"keywords": [
		"javascript",
		"typescript",
		"browser",
		"dom",
		"esm",
		"tree-shakable",
		"zero-dependencies",
		"events",
		"viewport",
		"helpers",
		"utility"
	],
	"bugs": {
		"url": "https://github.com/Tokimon/jsfns/issues"
	},
	"homepage": "https://tokimon.github.io/jsfns/web",
	"scripts": {
		"prepublishOnly": "pnpm validate && pnpm build && pnpm readme",
		"postpublish": "pnpm clean",
		"dry-run": "pnpm validate && pnpm build && npm pack --dry-run",
		"build": "tsgo -p ./tsconfig.build.json",
		"clean": "rm -rf ./dist",
		"missing": "../../bin/missing.sh",
		"readme": "tsx ../../readme-builder/build.ts",
		"typecheck": "tsgo -p tsconfig.json",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage.reporter=json-summary",
		"typedoc:validate": "typedoc --tsconfig tsconfig.typedoc.json --entryPoints \"src/*.ts\" --validation --treatWarningsAsErrors --emit none",
		"lint": "biome check",
		"format": "biome check --write",
		"validate": "pnpm lint && pnpm typecheck && pnpm typedoc:validate && pnpm test:coverage",
		"release": "pnpm publish --no-git-checks"
	},
	"dependencies": {
		"@jsfns/core": "workspace:^"
	},
	"devDependencies": {
		"jsdom": "^29.1.1"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		"./*.js": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		}
	}
}
