{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"lib": ["es2022", "DOM"],
		"module": "nodenext",
		"target": "ES2022",
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"declaration": true,
		"skipLibCheck": true,
		"noImplicitAny": true,
		"sourceMap": false,
		"allowJs": false,
		"checkJs": false,
		"strictNullChecks": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"paths": {
			"@jsfns/core/*": ["./packages/core/src/*"],
			"@jsfns/web/*": ["./packages/web/src/*"]
		}
	}
}
