{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"lib": ["ES2023", "DOM"],
		"module": "nodenext",
		"target": "ES2023",
		"allowImportingTsExtensions": true,
		"declaration": true,
		"skipLibCheck": true,
		"noImplicitAny": true,
		"sourceMap": false,
		"allowJs": false,
		"checkJs": false,
		"strictNullChecks": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"types": ["node"]
	}
}
